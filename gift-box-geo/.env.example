# ── 复制本文件为 .env 再填写（.env 已被 .gitignore，密钥不进仓库）──
#    cp .env.example .env

# 火山方舟（豆包）——中文侧真实引擎
# 控制台：https://console.volcengine.com/ark  (开通后拿 API Key + 推理接入点)
ARK_API_KEY=
# 豆包模型 id 或推理接入点 id（形如 doubao-1-5-pro-32k-250115 或 ep-2024xxxxxxxx）
ARK_MODEL=
# 一般不用改
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 可选：联网/搜索应用(bot) id；配了它豆包回答会带 citations + 商品卡（更适合 GEO 侦察）
ARK_BOT_ID=

# 英文引擎（暂未启用——给 key 即可一键切真；当前英文侧走 mock 占位）
PERPLEXITY_API_KEY=
OPENAI_API_KEY=

# 限速 / 重试 / 超时
GEO_RATE_LIMIT_MIN_INTERVAL_SEC=1.5
GEO_HTTP_TIMEOUT_SEC=60
GEO_MAX_RETRIES=3
